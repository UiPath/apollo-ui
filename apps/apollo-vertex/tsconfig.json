{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/components/ui/accordion": ["./registry/accordion/accordion"],
      "@/components/ui/alert": ["./registry/alert/alert"],
      "@/components/ui/alert-dialog": ["./registry/alert-dialog/alert-dialog"],
      "@/components/ui/aspect-ratio": ["./registry/aspect-ratio/aspect-ratio"],
      "@/components/ui/avatar": ["./registry/avatar/avatar"],
      "@/components/ui/badge": ["./registry/badge/badge"],
      "@/components/ui/breadcrumb": ["./registry/breadcrumb/breadcrumb"],
      "@/components/ui/button": ["./registry/button/button"],
      "@/components/ui/button-group": ["./registry/button-group/button-group"],
      "@/components/ui/calendar": ["./registry/calendar/calendar"],
      "@/components/ui/card": ["./registry/card/card"],
      "@/components/ui/carousel": ["./registry/carousel/carousel"],
      "@/components/ui/chart": ["./registry/chart/chart"],
      "@/lib/charts-core": ["./registry/charts-core/charts-core"],
      "@/lib/data-fabric-adapter": [
        "./registry/data-fabric-adapter/data-fabric-adapter"
      ],
      "@/lib/insights-adapter": [
        "./registry/insights-adapter/insights-adapter"
      ],
      "@/components/ui/line-chart": ["./registry/line-chart/line-chart"],
      "@/components/ui/multi-line-chart": [
        "./registry/multi-line-chart/multi-line-chart"
      ],
      "@/components/ui/bar-chart": ["./registry/bar-chart/bar-chart"],
      "@/components/ui/distribution-chart": [
        "./registry/distribution-chart/distribution-chart"
      ],
      "@/components/ui/kpi-chart": ["./registry/kpi-chart/kpi-chart"],
      "@/components/ui/table-chart": ["./registry/table-chart/table-chart"],
      "@/components/ui/checkbox": ["./registry/checkbox/checkbox"],
      "@/components/ui/collapsible": ["./registry/collapsible/collapsible"],
      "@/components/ui/combobox": ["./registry/combobox/combobox"],
      "@/components/ui/command": ["./registry/command/command"],
      "@/components/ui/context-menu": ["./registry/context-menu/context-menu"],
      "@/components/ui/data-table": ["./registry/data-table/index"],
      "@/components/ui/dialog": ["./registry/dialog/dialog"],
      "@/components/ui/drawer": ["./registry/drawer/drawer"],
      "@/components/ui/dropdown-menu": [
        "./registry/dropdown-menu/dropdown-menu"
      ],
      "@/components/ui/empty": ["./registry/empty/empty"],
      "@/components/ui/feedback-vote-widget": [
        "./registry/feedback-vote-widget/feedback-vote-widget"
      ],
      "@/components/ui/field": ["./registry/field/field"],
      "@/components/ui/filter-dropdown": ["./registry/filter-dropdown/index"],
      "@/components/ui/form": ["./registry/form/index"],
      "@/components/ui/hover-card": ["./registry/hover-card/hover-card"],
      "@/components/ui/input": ["./registry/input/input"],
      "@/components/ui/input-group": ["./registry/input-group/input-group"],
      "@/components/ui/input-otp": ["./registry/input-otp/input-otp"],
      "@/components/ui/item": ["./registry/item/item"],
      "@/components/ui/kbd": ["./registry/kbd/kbd"],
      "@/components/ui/label": ["./registry/label/label"],
      "@/components/ui/menubar": ["./registry/menubar/menubar"],
      "@/components/ui/metric-card": ["./registry/metric-card/metric-card"],
      "@/components/ui/native-select": [
        "./registry/native-select/native-select"
      ],
      "@/components/ui/navigation-menu": [
        "./registry/navigation-menu/navigation-menu"
      ],
      "@/components/ui/onboarding-tour-joyride": [
        "./registry/onboarding-tour-joyride/index"
      ],
      "@/components/ui/page-header": ["./registry/page-header/page-header"],
      "@/components/ui/pagination": ["./registry/pagination/pagination"],
      "@/components/ui/popover": ["./registry/popover/popover"],
      "@/components/ui/progress": ["./registry/progress/progress"],
      "@/components/ui/radio-group": ["./registry/radio-group/radio-group"],
      "@/components/ui/resizable": ["./registry/resizable/resizable"],
      "@/components/ui/scroll-area": ["./registry/scroll-area/scroll-area"],
      "@/components/ui/select": ["./registry/select/select"],
      "@/components/ui/separator": ["./registry/separator/separator"],
      "@/components/ui/sheet": ["./registry/sheet/sheet"],
      "@/components/ui/shell": ["./registry/shell/shell"],
      "@/components/ui/sidebar": ["./registry/sidebar/sidebar"],
      "@/components/ui/skeleton": ["./registry/skeleton/skeleton"],
      "@/components/ui/slider": ["./registry/slider/slider"],
      "@/components/ui/solution-tests": ["./registry/solution-tests/index"],
      "@/components/ui/sonner": ["./registry/sonner/sonner"],
      "@/components/ui/spinner": ["./registry/spinner/spinner"],
      "@/components/ui/stepper": ["./registry/stepper/index"],
      "@/components/ui/switch": ["./registry/switch/switch"],
      "@/components/ui/table": ["./registry/table/table"],
      "@/components/ui/tabs": ["./registry/tabs/tabs"],
      "@/components/ui/textarea": ["./registry/textarea/textarea"],
      "@/components/ui/theme-provider": [
        "./registry/theme-provider/theme-provider"
      ],
      "@/components/ui/toggle": ["./registry/toggle/toggle"],
      "@/components/ui/toggle-group": ["./registry/toggle-group/toggle-group"],
      "@/components/ui/tooltip": ["./registry/tooltip/tooltip"],
      "@/hooks/use-mobile": ["./registry/use-mobile/use-mobile"],
      "@/hooks/useReactTableCompat": [
        "./registry/use-data-table/useReactTableCompat"
      ],
      "@/components/theme-provider/theme-provider": [
        "./registry/theme-provider/theme-provider"
      ],
      "@/lib/feature-flag-provider": [
        "./registry/feature-flag-provider/feature-flag-provider"
      ],
      "@/lib/feature-flag-provider/types": [
        "./registry/feature-flag-provider/types"
      ],
      "@/lib/feature-flag-provider/proteus-adapter": [
        "./registry/feature-flag-provider/proteus-adapter"
      ],
      "@/hooks/use-feature-flag": [
        "./registry/use-feature-flag/use-feature-flag"
      ],
      "@/components/ui/feature-flag-guard": [
        "./registry/feature-flag-guard/feature-flag-guard"
      ],
      "@/components/ui/protected-feature-route": [
        "./registry/protected-feature-route/protected-feature-route"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
